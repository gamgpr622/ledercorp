---
export const prerender = false;

import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Hero from "../components/Hero.astro";
import ProductCard from "../components/ProductCard.astro";
import ProductModal from "../components/ProductModal.astro";
import OfertasSlider from "../components/OfertasSlider.astro";
import ProximosIngresos from "../components/ProximosIngresos.astro";
import Reviews from "../components/Reviews.astro";
import InfoSection from "../components/InfoSection.astro";
import Footer from "../components/Footer.astro";
import WhatsAppButton from "../components/WhatsAppButton.astro";
import {
	getProducts,
	getConfig,
	getSlides,
	getReviews,
	getInfo,
	getReservas,
} from "../lib/sheet";

const config = await getConfig();
const products = await getProducts();
const slides = await getSlides();
const reviews = await getReviews();
const info = await getInfo();
const reservas = await getReservas();

const novedades = products
	.filter((p) => p.novedad?.toLowerCase() === "si")
	.slice(0, 6);
const catalogo = products.sort(() => Math.random() - 0.5).slice(0, 10);
---

<Layout
	title={config.nombre}
	color={config.color_primario}
	faviconLetras={config.favicon_letras || config.nombre.charAt(0)}
>
	<Navbar config={config} />

	<Hero slides={slides} />

	<!-- Novedades -->
	{
		novedades.length > 0 && (
			<div id="novedades" class="max-w-7xl mx-auto px-[5%] py-16">
				<h2 style="font-family: var(--font-display); font-size: clamp(2rem, 4vw, 3rem); letter-spacing: 0.05em; color: var(--text);">
					NOVEDADES
				</h2>
				<p class="text-sm mb-8 mt-1" style="color: var(--text-muted);">
					Lo recién llegado
				</p>
				<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
					{novedades.map((product) => (
						<ProductCard product={product} config={config} />
					))}
				</div>
			</div>
		)
	}

	<OfertasSlider products={products} config={config} />

	<!-- Catálogo random -->
	<div class="max-w-7xl mx-auto px-[5%] py-16">
		<h2
			style="font-family: var(--font-display); font-size: clamp(2rem, 4vw, 3rem); letter-spacing: 0.05em; color: var(--text);"
		>
			CATÁLOGO
		</h2>
		<p class="text-sm mb-8 mt-1" style="color: var(--text-muted);">
			Explorá todo el stock
		</p>
		<div class="grid grid-cols-2 md:grid-cols-4 gap-6">
			{
				catalogo.map((product) => (
					<ProductCard product={product} config={config} />
				))
			}

			<!-- Card ver catálogo — solo desktop -->

			<a
				href="/catalogo"
				class="hidden md:flex rounded-2xl flex-col
			items-center justify-center gap-3 border-2 border-dashed
			transition-all duration-200 min-h-[300px]"
				style="border-color:
			var(--border);"
				onmouseenter="this.style.borderColor='var(--color-primary)';
			this.querySelector('p').style.color='var(--color-primary)'"
				onmouseleave="this.style.borderColor='var(--border)';
			this.querySelector('p').style.color='var(--text-muted)'"
			>
				<span class="text-4xl" style="color: var(--text-muted);">→</span
				>
				<p
					class="font-bold text-sm text-center px-4 transition-colors duration-200"
					style="color: var(--text-muted);"
				>
					Ver catálogo completo
				</p>
			</a>
		</div>

		<!-- Botón ver más — solo mobile -->
		<div class="flex justify-center mt-8 md:hidden">
			<a
				href="/catalogo"
				class="flex items-center gap-2 px-8 py-3 rounded-full
		font-bold text-sm transition-all duration-200 border"
				style="border-color: var(--text); color: var(--text);"
				onmouseenter="this.style.background='var(--text)';
		this.style.color='var(--bg)'"
				onmouseleave="this.style.background='transparent';
		this.style.color='var(--text)'"
			>
				Ver catálogo completo →
			</a>
		</div>
	</div>

	<ProximosIngresos reservas={reservas} whatsapp={config.whatsapp} />

	{reviews.length > 0 && <Reviews reviews={reviews} />}
	<InfoSection info={info} />
	<Footer config={config} />
	<WhatsAppButton whatsapp={config.whatsapp} />

	<!-- Modal -->
	<ProductModal />

	<script define:vars={{ moneda: config.moneda, whatsapp: config.whatsapp }}>
		const PRIMARY = getComputedStyle(document.documentElement)
			.getPropertyValue("--color-primary")
			.trim();

		document.querySelectorAll(".product-card").forEach((card) => {
			card.addEventListener("click", () => {
				const data = JSON.parse(
					card.getAttribute("data-product") || "{}",
				);
				window.__openModal(data, moneda, PRIMARY, whatsapp);
			});
		});
	</script>
</Layout>
