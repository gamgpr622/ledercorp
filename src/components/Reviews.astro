---
import type { Review } from '../types'

interface Props {
  reviews: Review[]
}

const { reviews } = Astro.props

const MAX_VISIBLE = 3
const initial = reviews.slice(0, MAX_VISIBLE)
const extra = reviews.slice(MAX_VISIBLE)
---

<div class="py-16" style="background: var(--bg-secondary);">
  <div class="max-w-7xl mx-auto px-[5%]">

    <!-- Header -->
    <p class="text-xs font-bold uppercase tracking-widest mb-2" style="color: var(--text-muted);">Testimonios</p>
    <h2 style="font-family: var(--font-display); font-size: clamp(2rem, 4vw, 3rem); letter-spacing: 0.05em; color: var(--text);">CLIENTES FELICES</h2>

    <!-- Lista inicial (3 reseñas) -->
    <div class="flex flex-col mt-10">
      {initial.map((review, i) => (
        <div
          class={`py-8 grid grid-cols-1 md:grid-cols-[220px_1fr] gap-6 md:gap-12 ${i < initial.length - 1 || extra.length > 0 ? 'border-b' : ''}`}
          style="border-color: var(--border);"
        >
          <!-- Avatar, nombre y estrellas -->
          <div class="flex md:flex-col items-center md:items-start gap-4 md:gap-3">
            <div
              class="w-14 h-14 md:w-16 md:h-16 rounded-full flex items-center justify-center shrink-0 text-white"
              style="background: var(--color-primary); font-family: var(--font-display); font-size: 1.6rem;"
            >
              {review.nombre.charAt(0).toUpperCase()}
            </div>
            <div>
              <p class="font-bold text-base" style="color: var(--text);">{review.nombre}</p>
              <p class="text-sm mt-0.5" style="color: #f59e0b;">
                {'★'.repeat(Number(review.estrellas))}
                <span class="ml-1 text-xs" style="color: var(--text-muted);">{review.estrellas}/5</span>
              </p>
            </div>
          </div>

          <!-- Texto + fotos -->
          <div class="flex flex-col gap-4 justify-center">
            <p class="text-base leading-relaxed" style="color: var(--text-muted);">"{review.texto}"</p>

            <!-- Fotos si existen -->
            {(review.foto1 || review.foto2) && (
              <div class="flex gap-2 justify-end">
                {review.foto1 && (
                  <button
                    class="review-photo-btn w-16 h-16 md:w-20 md:h-20 rounded-xl overflow-hidden shrink-0 border-2 transition-all duration-200"
                    style="border-color: var(--border);"
                    data-src={review.foto1}
                    onmouseenter="this.style.borderColor='var(--color-primary)'"
                    onmouseleave="this.style.borderColor='var(--border)'"
                  >
                    <img src={review.foto1} alt="Foto del cliente" class="w-full h-full object-cover" />
                  </button>
                )}
                {review.foto2 && (
                  <button
                    class="review-photo-btn w-16 h-16 md:w-20 md:h-20 rounded-xl overflow-hidden shrink-0 border-2 transition-all duration-200"
                    style="border-color: var(--border);"
                    data-src={review.foto2}
                    onmouseenter="this.style.borderColor='var(--color-primary)'"
                    onmouseleave="this.style.borderColor='var(--border)'"
                  >
                    <img src={review.foto2} alt="Foto del cliente" class="w-full h-full object-cover" />
                  </button>
                )}
              </div>
            )}
          </div>
        </div>
      ))}
    </div>

    <!-- Reseñas extra (ocultas por defecto) -->
    {extra.length > 0 && (
      <div id="extra-reviews" class="hidden flex-col">
        {extra.map((review, i) => (
          <div
            class={`py-8 grid grid-cols-1 md:grid-cols-[220px_1fr] gap-6 md:gap-12 border-b`}
            style="border-color: var(--border);"
          >
            <div class="flex md:flex-col items-center md:items-start gap-4 md:gap-3">
              <div
                class="w-14 h-14 md:w-16 md:h-16 rounded-full flex items-center justify-center shrink-0 text-white"
                style="background: var(--color-primary); font-family: var(--font-display); font-size: 1.6rem;"
              >
                {review.nombre.charAt(0).toUpperCase()}
              </div>
              <div>
                <p class="font-bold text-base" style="color: var(--text);">{review.nombre}</p>
                <p class="text-sm mt-0.5" style="color: #f59e0b;">
                  {'★'.repeat(Number(review.estrellas))}
                  <span class="ml-1 text-xs" style="color: var(--text-muted);">{review.estrellas}/5</span>
                </p>
              </div>
            </div>
            <div class="flex flex-col gap-4 justify-center">
              <p class="text-base leading-relaxed" style="color: var(--text-muted);">"{review.texto}"</p>
              {(review.foto1 || review.foto2) && (
                <div class="flex gap-2 justify-end">
                  {review.foto1 && (
                    <button
                      class="review-photo-btn w-16 h-16 md:w-20 md:h-20 rounded-xl overflow-hidden shrink-0 border-2 transition-all duration-200"
                      style="border-color: var(--border);"
                      data-src={review.foto1}
                      onmouseenter="this.style.borderColor='var(--color-primary)'"
                      onmouseleave="this.style.borderColor='var(--border)'"
                    >
                      <img src={review.foto1} alt="Foto del cliente" class="w-full h-full object-cover" />
                    </button>
                  )}
                  {review.foto2 && (
                    <button
                      class="review-photo-btn w-16 h-16 md:w-20 md:h-20 rounded-xl overflow-hidden shrink-0 border-2 transition-all duration-200"
                      style="border-color: var(--border);"
                      data-src={review.foto2}
                      onmouseenter="this.style.borderColor='var(--color-primary)'"
                      onmouseleave="this.style.borderColor='var(--border)'"
                    >
                      <img src={review.foto2} alt="Foto del cliente" class="w-full h-full object-cover" />
                    </button>
                  )}
                </div>
              )}
            </div>
          </div>
        ))}
      </div>
    )}

    <!-- Botón ver más -->
    {extra.length > 0 && (
      <div class="flex justify-center mt-8">
        <button
          id="toggle-reviews"
          class="flex items-center gap-2 px-8 py-3 rounded-full font-bold text-sm transition-all duration-200 border"
          style="border-color: var(--text); color: var(--text); background: transparent;"
          onmouseenter="this.style.background='var(--text)'; this.style.color='var(--bg)'"
          onmouseleave="this.style.background='transparent'; this.style.color='var(--text)'"
        >
          <span id="toggle-label">Ver {extra.length} reseñas más</span>
          <span id="toggle-icon">↓</span>
        </button>
      </div>
    )}

  </div>
</div>

<!-- Lightbox para fotos -->
<div id="photo-lightbox" class="hidden fixed inset-0 z-50 items-center justify-center p-4" style="background: rgba(0,0,0,0.9);">
  <button id="close-lightbox" class="absolute top-4 right-4 text-white text-3xl" style="background: none; border: none; cursor: pointer;">✕</button>
  <img id="lightbox-img" src="" alt="Foto del cliente" class="max-w-full max-h-[90vh] rounded-2xl object-contain" />
</div>

<script>
  // Ver más / ver menos
  const toggleBtn = document.getElementById('toggle-reviews')
  const extraReviews = document.getElementById('extra-reviews')
  const toggleLabel = document.getElementById('toggle-label')
  const toggleIcon = document.getElementById('toggle-icon')
  let expanded = false

  if (toggleBtn && extraReviews) {
    toggleBtn.addEventListener('click', () => {
      expanded = !expanded
      extraReviews.classList.toggle('hidden', !expanded)
      extraReviews.classList.toggle('flex', expanded)
      toggleLabel!.textContent = expanded ? 'Ver menos' : `Ver ${extraReviews.querySelectorAll('.py-8').length} reseñas más`
      toggleIcon!.textContent = expanded ? '↑' : '↓'
    })
  }

  // Lightbox
  const lightbox = document.getElementById('photo-lightbox')!
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement
  const closeLightbox = document.getElementById('close-lightbox')!

  document.querySelectorAll('.review-photo-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const src = btn.getAttribute('data-src') || ''
      lightboxImg.src = src
      lightbox.style.display = 'flex'
    })
  })

  closeLightbox.addEventListener('click', () => {
    lightbox.style.display = 'none'
  })

  lightbox.addEventListener('click', e => {
    if (e.target === lightbox) lightbox.style.display = 'none'
  })
</script>